// Pattern: boundary_values
// Purpose: Values exactly at and adjacent to activation_min=-20, activation_max=50. Catches off-by-one errors in clamp comparison.
// Requantize mode: N/A — clamp activation has no requantize step
// NOTE: partial_sum omitted — this is an elementwise op with no MAC

int tflite_single_rounding = 0;
int num_elements = 16;
int input_zero_point = 0;
int output_zero_point = 0;
int activation_min = -20;
int activation_max = 50;

int8_t input[16] = {-128, -21, -20, -19, 49, 50, 51, 127, 0, -1, 1, -20, 50, -128, 127, -15};
int8_t golden[16] = {-20, -20, -20, -19, 49, 50, 50, 50, 0, -1, 1, -20, 50, -20, 50, -15};
