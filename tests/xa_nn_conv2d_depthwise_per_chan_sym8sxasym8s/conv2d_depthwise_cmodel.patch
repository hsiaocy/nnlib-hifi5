 static inline int32_t dw_doubling_high_mult(int32_t m1, int32_t m2)
 {
-    return (int32_t)(((int64_t)m1 * (int64_t)m2) >> 31);
+    /* gemmlowp::SaturatingRoundingDoublingHighMul
+     *
+     * Equivalent to: round(m1 * m2 * 2 / 2^32) saturated to int32, where
+     * the rounding is "to nearest, ties away from zero" (the +/-2^30 nudge).
+     *
+     * Bug history: a previous version did just (m1*m2)>>31 without the nudge,
+     * which truncates instead of rounds and produced 1-bit mismatches against
+     * NNLib for ~50% of inputs.  Always include the nudge.
+     */
+    int32_t overflow = (m1 == INT32_MIN && m2 == INT32_MIN);
+    int64_t prod     = (int64_t)m1 * (int64_t)m2;
+    int32_t nudge    = (prod >= 0) ? (1 << 30) : (1 - (1 << 30));
+    int32_t result   = (int32_t)((prod + nudge) / (1LL << 31));
+    return overflow ? INT32_MAX : result;
 }
 
